<?xml version="1.0" encoding="utf-8"?>
<!--
    Cyberpunk candlestick icon matching the SAIT Next Gen brand palette.
    Teal/cyan (#00E5FF) for bull candles, magenta/pink (#FF00CC) for bear candles.
