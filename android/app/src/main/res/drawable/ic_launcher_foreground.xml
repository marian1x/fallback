    <path android:fillColor="#FF00CC" android:pathData="M50,36 a2,2 0 1,0 4,0 a2,2 0 1,0 -4,0"/>
    <path android:fillColor="#00E5FF" android:pathData="M65,17 a2,2 0 1,0 4,0 a2,2 0 1,0 -4,0"/>
    <path android:fillColor="#00FFEE" android:pathData="M82,11 a2,2 0 1,0 4,0 a2,2 0 1,0 -4,0"/>

