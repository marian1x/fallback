    <path android:fillColor="#00E5FF"   android:pathData="M33,40h8v20h-8z"/>
    <path android:strokeColor="#00E5FF" android:strokeWidth="1.5"
          android:pathData="M37,31 L37,66"/>

    <!-- ── Candle 3  BEAR  cx=52 ───────────────────────── -->
    <path android:fillColor="#55FF00CC" android:pathData="M46,44h12v20h-12z"/>
    <path android:fillColor="#FF00CC"   android:pathData="M48,46h8v16h-8z"/>
    <path android:strokeColor="#FF00CC" android:strokeWidth="1.5"
          android:pathData="M52,37 L52,70"/>

    <!-- ── Candle 4  BULL  cx=67 ───────────────────────── -->
    <path android:fillColor="#5500E5FF" android:pathData="M61,26h12v26h-12z"/>
    <path android:fillColor="#00E5FF"   android:pathData="M63,28h8v22h-8z"/>
    <path android:strokeColor="#00E5FF" android:strokeWidth="1.5"
          android:pathData="M67,18 L67,58"/>

