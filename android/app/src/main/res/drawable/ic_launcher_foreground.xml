    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Price-axis baseline -->
    <path
        android:strokeColor="#1A3050"
        android:strokeWidth="1"
        android:pathData="M14,86 L94,86"/>

    <!-- ── Candle 1  BEAR  cx=22 ───────────────────────── -->
    <path android:fillColor="#55FF00CC" android:pathData="M16,52h12v22h-12z"/>
